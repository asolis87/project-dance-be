# Better Auth Configuration
# Secreto para encriptación y firma (mínimo 32 caracteres)
# Genera uno con: openssl rand -base64 32
BETTER_AUTH_SECRET=cambiar-este-secreto-en-produccion-minimo-32-caracteres-aleatorios

# URL base de la aplicación
BETTER_AUTH_URL=http://localhost:3000

# Environment
NODE_ENV=development

# Server Configuration
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://dance:dance_dev@localhost:5433/project_dance

# Google OAuth (opcional, dejar vacío para desactivar)
# GOOGLE_CLIENT_ID=tu-google-client-id
# GOOGLE_CLIENT_SECRET=tu-google-client-secret

# Orígenes de confianza para CORS (separados por coma)
# TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3001

# Resend (proveedor de email)
# Obtén tu API key en https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxx
# EMAIL_FROM=Dance Academy <noreply@tudominio.com>
